# Server
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string

# Who can sign in. Use * to allow any Kick account.
ALLOWED_BROADCASTER_IDS=*
# Full dashboard access (your Kick broadcaster user ID). Everyone else gets Stream stats + Only Pixels.
OWNER_BROADCASTER_IDS=1183030
# Legacy fallback allow-list by Kick username (only used when ALLOWED_BROADCASTER_IDS is not *)
ALLOWED_KICK_USERNAMES=na5ty
# Default channel for chat widget / OBS when no token store yet
DEFAULT_BROADCASTER_ID=1183030

# Kick City / FiveM kick_rewards API (same routes as old Kick Analytics :5000 API)
# FiveM config.lua: Config.API.BaseURL = "https://na5ty.com/api"
# Comma-separated slug:broadcaster_id pairs for monitored Kick channels
KICK_REWARDS_CHANNELS=na5ty:1183030
# Extra partnered streamer slugs (no broadcaster id required — resolved on boot)
KICK_REWARD_PARTNER_SLUGS=andy1993,vikinggaming94,d0sil,devilmaykill579,lonewolfclyde
# Log + ring-buffer recent chat for these channels (pusher monitor)
KICK_CHAT_DEBUG_SLUGS=andy1993
# Extra partner slugs for Pusher chat monitor (same as old KickApi config streamers list)
KICK_MONITOR_EXTRA_SLUGS=
# Pusher WebSocket chat capture (like KickApi enhanced_chat_monitor.py). Set 0 to disable.
KICK_PUSHER_MONITOR=1
# Optional: require X-API-Key header from FiveM (set same value in Config.API.APIKey)
KICK_REWARDS_API_KEY=

# Twitch — https://dev.twitch.tv/console/apps
# Redirect URL: http://localhost:3000/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Kick — https://kick.com/settings/developer
# Redirect URLs (OAuth sign-in only — NOT where chat webhooks go):
#   http://localhost:3000/auth/kick/callback
#   https://na5ty.com/auth/kick/callback
#   https://www.na5ty.com/auth/kick/callback
# Webhook URL (separate "Enable Webhooks" field in Kick Developer):
#   https://na5ty.com/webhooks/kick
# For localhost dev, use ngrok and set WEBHOOK_URL to your tunnel + /webhooks/kick.
WEBHOOK_URL=
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# Spotify — https://developer.spotify.com/dashboard
# Redirect URI must use 127.0.0.1 (Spotify blocks localhost). Open site at http://127.0.0.1:3000 to connect.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback
# Requires Spotify Premium on the stream PC (active Spotify app/device).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Stake.us — x-access-token from browser DevTools (Network → graphql → request headers)
STAKE_ACCESS_TOKEN=
STAKE_AFFILIATE_CODE=na5ty

# Govee LAN (optional) — comma-separated device IPs if multicast scan fails
# GOVEE_LAN_SCAN=192.168.1.50,192.168.1.51
